# =============================================================================
#  VMD Staging Environment Variables (Template)
# -----------------------------------------------------------------------------
#  목적: 프로덕션 배포 직전 Playwright E2E 가 돌아가는 사전 검증 환경.
#         값/리소스는 prod 와 동일 키 셋을 가지되 도메인/시크릿/스케일이 다름.
#
#  사용 방법:
#    1. cp infra/env/staging.env.example infra/env/staging.env
#    2. 모든 값을 실제 staging 시크릿으로 채운다.
#    3. staging.env 는 git 미커밋. 시크릿 관리는 infra/env/README.md 참조.
#
#  Prod 와의 차이 요약:
#    - 도메인: staging.do-goproject.com / cdn-staging.do-goproject.com
#    - 별도 S3 버킷 / CloudFront 배포
#    - DEBUG=False (프로덕션과 동일)이지만 SENTRY 샘플링 ↑, 로그 레벨 ↑
#    - 이메일/알림은 mock 또는 dev 채널로
# =============================================================================


# -----------------------------------------------------------------------------
# 0. Compose / Runtime Meta
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=vmd-staging
ENVIRONMENT=staging
TZ=Asia/Seoul


# -----------------------------------------------------------------------------
# 1. Container Registry & Image Tags
# -----------------------------------------------------------------------------
REGISTRY=
# Staging 은 보통 단일 색상 (Blue/Green 불필요). prod 와 변수명만 통일.
IMAGE_TAG_BLUE=dev-latest
IMAGE_TAG_GREEN=dev-latest


# -----------------------------------------------------------------------------
# 2. Django
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=staging.do-goproject.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.do-goproject.com
DJANGO_LOG_LEVEL=DEBUG
DJANGO_STATIC_ROOT=/var/www/static
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60


# -----------------------------------------------------------------------------
# 3. PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=vmd_staging
POSTGRES_USER=vmd_app
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://vmd_app:CHANGE_ME@postgres:5432/vmd_staging


# -----------------------------------------------------------------------------
# 4. Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/2


# -----------------------------------------------------------------------------
# 5. Celery
# -----------------------------------------------------------------------------
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_AI_QUEUE=ai
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True


# -----------------------------------------------------------------------------
# 6. YOLOv11-seg
# -----------------------------------------------------------------------------
YOLO_MODEL_PATH=/models/yolov11s-seg.pt
YOLO_DEVICE=cpu
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.50
YOLO_IMG_SIZE=1024
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
YOLO_READY_FLAG_PATH=/tmp/worker_ready

# Phase 2 대비 (현재 미사용)
# YOLO_MODEL_S3_URI=s3://vmd-models-staging/yolov11-seg/v1.2.3/weights.pt
# YOLO_MODEL_VERSION=v1.2.3
# YOLO_MODEL_SHA256=
# YOLO_MODEL_CACHE_DIR=/var/cache/vmd-models


# -----------------------------------------------------------------------------
# 7. AWS (별도 staging 버킷 / 배포)
# -----------------------------------------------------------------------------
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

AWS_S3_BUCKET=vmd-assets-staging
AWS_S3_REGION=ap-northeast-2
AWS_S3_PRESIGNED_PUT_TTL=300
AWS_S3_PRESIGNED_GET_TTL=300
AWS_S3_UPLOAD_MAX_BYTES=104857600

AWS_CLOUDFRONT_DOMAIN=cdn-staging.do-goproject.com
AWS_CLOUDFRONT_DISTRIBUTION_ID=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_PATH=/run/secrets/cloudfront_private_key.pem
AWS_CLOUDFRONT_SIGNED_URL_TTL=300


# -----------------------------------------------------------------------------
# 8. Auth
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://staging.do-goproject.com/api/auth/google/callback


# -----------------------------------------------------------------------------
# 9. JWT
# -----------------------------------------------------------------------------
JWT_SIGNING_KEY=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600


# -----------------------------------------------------------------------------
# 10. Security / CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://staging.do-goproject.com
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True


# -----------------------------------------------------------------------------
# 11. Observability — staging 은 샘플링/로그 레벨을 더 적극적으로
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=1.0
LOG_LEVEL=DEBUG
LOG_STREAM_NAME=vmd-staging


# -----------------------------------------------------------------------------
# 12. Frontend (Build-time)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://staging.do-goproject.com/api
VITE_WS_BASE_URL=wss://staging.do-goproject.com/ws
VITE_CDN_BASE_URL=https://cdn-staging.do-goproject.com
VITE_SENTRY_DSN=


# -----------------------------------------------------------------------------
# 13. Backup
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=vmd-backup-staging
BACKUP_S3_PREFIX=postgres/
BACKUP_RETENTION_DAYS=7


# -----------------------------------------------------------------------------
# 14. E2E (Playwright) — Staging 에서만 의미 있는 항목
# -----------------------------------------------------------------------------
# Playwright 가 사용할 시드 계정 (staging 전용, prod 와 절대 공유 X)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_BASE_URL=https://staging.do-goproject.com