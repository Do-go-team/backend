# =============================================================================
#  VMD Production Environment Variables (Template)
# -----------------------------------------------------------------------------
#  사용 방법:
#    1. 본 파일을 복사하여 `prod.env` 로 저장한다.
#         cp infra/env/prod.env.example infra/env/prod.env
#    2. 모든 값을 실제 운영 시크릿으로 채운다.
#    3. `prod.env` 는 절대 git에 커밋하지 않는다 (.gitignore의 `.env.*` 룰로 보호됨).
#    4. 시크릿 주입 절차 / 운영 룰은 `infra/env/README.md` 참조.
#
#  주의:
#    - 본 파일에는 실제 값을 절대 적지 않는다 (모든 값은 빈칸 유지).
#    - 새 키 추가 시 팀원에게 별도 채널로 통지 (.ai/ 정책상 자동 동기화 안 됨).
# =============================================================================


# -----------------------------------------------------------------------------
# 0. Compose / Runtime Meta
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=vmd-prod
ENVIRONMENT=production
TZ=Asia/Seoul


# -----------------------------------------------------------------------------
# 1. Container Registry & Image Tags (Blue/Green)
# -----------------------------------------------------------------------------
# GitLab Container Registry 또는 ECR 경로
REGISTRY=
# 두 색상 중 현재 활성 색상이 사용하는 태그 (= GitLab short SHA 또는 release tag)
IMAGE_TAG_BLUE=stable
# Standby 색상이 받게 될 새 이미지 태그. 배포 직전 Jenkins 가 주입.
IMAGE_TAG_GREEN=stable


# -----------------------------------------------------------------------------
# 2. Django (django-ninja, Gunicorn sync workers / WSGI)
# -----------------------------------------------------------------------------
# 단일 settings.py (config/settings.py). 분할 settings 도입 시 config.settings.prod 로 변경.
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=do-goproject.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://do-goproject.com
DJANGO_LOG_LEVEL=INFO
# 정적 파일 수집 경로 (컨테이너 내부 기준)
DJANGO_STATIC_ROOT=/var/www/static
# Gunicorn sync 워커 수 (-w). vCPU 와 메모리에 따라 조정.
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60

# 운영 보안 (SSL / HSTS)
# CLAUDE.md gotcha #8: HSTS 는 SSL 안정화 + 외부 모니터링 도입 후 활성화 예정.
# 지금 활성화하면 사고 발생 시 brick 위험 → 일단 0 으로 유지.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_HSTS_SECONDS=0


# -----------------------------------------------------------------------------
# 3. PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=vmd
POSTGRES_USER=vmd_app
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Connection pool / SSL (Phase 2 RDS 이전 시 활성화)
# DATABASE_SSLMODE=require


# -----------------------------------------------------------------------------
# 4. Redis (Cache + Celery Broker + Pub/Sub)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

REDIS_URL=redis://:CHANGE_ME@redis:6379/0
# DB 1: Django 캐시 / 세션 / Pub-Sub
REDIS_CACHE_URL=redis://:CHANGE_ME@redis:6379/4
REDIS_BLACKLIST_URL=redis://:CHANGE_ME@redis:6379/3
# DB 2: Celery 큐
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/1
# DB 3: Celery 결과
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/2


# -----------------------------------------------------------------------------
# 5. Celery (worker / queue 동작 튜닝)
# -----------------------------------------------------------------------------
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
# acks_late + reject_on_worker_lost 권장 (in-flight 작업 보호)
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True


# -----------------------------------------------------------------------------
# 6. YOLOv11-seg / AI Inference
# -----------------------------------------------------------------------------
# Phase 1 (현재): 호스트 bind mount 경로
YOLO_MODEL_PATH=/models/yolov11s-seg.pt
# CPU 추론 (Lightsail). GPU 도입 시 'cuda:0'
YOLO_DEVICE=cpu
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.50
YOLO_IMG_SIZE=1024
# CPU 스레드 제한 (PyTorch / OpenMP). vCPU 한도 내로 고정.
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
# Worker 가 모델 로드를 끝낸 뒤 생성하는 ready flag
YOLO_READY_FLAG_PATH=/tmp/worker_ready

# ----- Phase 2 마이그레이션 대비 (현재는 미사용, plan §2.3 ⚠️ 박스 참조) -----
# YOLO_MODEL_S3_URI=s3://vmd-models/yolov11-seg/v1.2.3/weights.pt
# YOLO_MODEL_VERSION=v1.2.3
# YOLO_MODEL_SHA256=
# YOLO_MODEL_CACHE_DIR=/var/cache/vmd-models


# -----------------------------------------------------------------------------
# 7. AWS (S3 + CloudFront + IAM)
# -----------------------------------------------------------------------------
AWS_REGION=ap-northeast-2
# 어플리케이션용 IAM User (S3 Put/Get/Delete 권한 최소화)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Phase 2 BE 통합 토글. True 면 common/s3.py 가 presigned URL 발급, False 면
# MEDIA_URL 로 fallback (로컬 개발 + 운영 사고 시 kill switch)
USE_S3=True

# 에셋 버킷 (3D GLB, 이미지, 도면)
AWS_S3_BUCKET=vmd-assets-prod
AWS_S3_REGION=ap-northeast-2
# Presigned URL TTL (초) — FE 가 받은 즉시 PUT/GET 한다는 가정
AWS_S3_PRESIGNED_PUT_TTL=300
AWS_S3_PRESIGNED_GET_TTL=300
# 업로드 최대 크기 (바이트). FE 검증 + Django 검증 모두에서 사용
AWS_S3_UPLOAD_MAX_BYTES=104857600   # 100 MB

# CloudFront (에셋 배포)
AWS_CLOUDFRONT_DOMAIN=cdn.do-goproject.com
AWS_CLOUDFRONT_DISTRIBUTION_ID=
# CloudFront Signed URL 발급에 필요한 키쌍
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY_PATH=/run/secrets/cloudfront_private_key.pem
AWS_CLOUDFRONT_SIGNED_URL_TTL=300


# -----------------------------------------------------------------------------
# 8. Auth (Google OAuth)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://do-goproject.com/api/auth/google/callback


# -----------------------------------------------------------------------------
# 9. JWT / Session
# -----------------------------------------------------------------------------
JWT_SIGNING_KEY=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600   # 14일


# -----------------------------------------------------------------------------
# 10. Security / CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://do-goproject.com
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# CORS / CSRF 둘 다 비어있을 때 fallback 으로 참조 (backend/config/settings.py)
FRONTEND_URL=https://do-goproject.com


# -----------------------------------------------------------------------------
# 11. Email (회원가입 인증 / 알림 메일)
# -----------------------------------------------------------------------------
# 운영: SMTP backend. 로컬 dev 는 console backend 사용 (.env.example 참조).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@do-goproject.com

# 인증 코드 정책 (초 단위, 발송 횟수)
EMAIL_CODE_TTL=300
EMAIL_RESEND_COOLDOWN=60
EMAIL_DAILY_LIMIT=10


# -----------------------------------------------------------------------------
# 12. Observability (Sentry / Log)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# APM(performance) sampling. 0.0 = error 만 추적 (event quota 절약).
# 운영 안정화 후 0.1 (10%) 로 상향하여 transaction 가시성 확보 검토.
SENTRY_TRACES_SAMPLE_RATE=0.0
# 4xx 응답 캡쳐 토글. 401/404/429 는 미들웨어가 자동 제외.
# quota 폭주 시 False 로 즉시 비활성 (재배포 필요).
SENTRY_FOURXX_CAPTURE_ENABLED=True
# Release 식별자. Jenkins 가 GIT_COMMIT 으로 주입 — 로컬/스테이징에서는 빈 값.
SENTRY_RELEASE=


# ----- ELK Stack (Elasticsearch + Kibana + Filebeat) -----
# Elasticsearch 의 'elastic' 슈퍼유저 비밀번호 (Tier-S, 32+ chars)
# 용도: ES 자체 부트스트랩 + Filebeat output 자격증명
ELASTIC_PASSWORD=

# Kibana 의 ES 접근 자격증명 (Tier-S).
# ES 8.0+ 부터 Kibana 가 'elastic' 슈퍼유저로 접근하면 reject
# service account 토큰 필수
KIBANA_SERVICE_ACCOUNT_TOKEN=

# Kibana X-Pack 암호화 키 (Tier-S, 32 chars 이상).
KIBANA_ENCRYPTION_KEY=
KIBANA_AUTH_USER=
KIBANA_AUTH_PASSWORD=
MM_WEBHOOK_ALERT=


# -----------------------------------------------------------------------------
# 13. Frontend (Build-time args, Vite)
# -----------------------------------------------------------------------------
# 빌드 시점에 주입 → 런타임에는 정적 자산에 박혀 있음
VITE_API_BASE_URL=https://do-goproject.com/api/v1
VITE_WS_BASE_URL=wss://do-goproject.com/ws
VITE_CDN_BASE_URL=https://cdn.do-goproject.com
VITE_SENTRY_DSN=
# Google Tag Manager (Phase 2 도입 예정 — 빈 값이면 GTM 비활성)
VITE_GTM_ID=


# -----------------------------------------------------------------------------
# 14. Backup (cron 운영)
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=vmd-backup-prod
BACKUP_S3_PREFIX=postgres/
BACKUP_RETENTION_DAYS=30


# -----------------------------------------------------------------------------
# 15. Detection Pipeline Callbacks
# -----------------------------------------------------------------------------
# ai-worker → Django callback URL (Docker 내부 통신).
CELERY_AI_QUEUE=ai
AI_DETECTION_TASK_NAME=ai_app.tasks.segment_product_image
PRODUCT_DETECTION_MAX_ITEMS=50
AI_CALLBACK_BASE_URL=https://do-goproject.com
BACKEND_BASE_URL=https://do-goproject.com
